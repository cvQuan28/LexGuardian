# LexGuardian — Environment Configuration
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ──────────────────────────────────────────
# App
# ──────────────────────────────────────────
APP_NAME=LexGuardian
DEBUG=false

# ──────────────────────────────────────────
# Database (PostgreSQL + pgvector)
# ──────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme
POSTGRES_DB=lexguardian

# Used by the backend directly (overridden in docker-compose for container networking)
DATABASE_URL=postgresql+asyncpg://postgres:changeme@localhost:5433/lexguardian

# ──────────────────────────────────────────
# LLM Provider — choose "gemini" or "ollama"
# ──────────────────────────────────────────
LLM_PROVIDER=gemini

# Google AI (required when LLM_PROVIDER=gemini)
GOOGLE_AI_API_KEY=your-google-ai-api-key-here

# Ollama (required when LLM_PROVIDER=ollama)
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=gemma3:12b

# LLM model (Gemini)
LLM_MODEL_FAST=gemini-2.5-flash
LLM_MAX_OUTPUT_TOKENS=8192

# ──────────────────────────────────────────
# Knowledge Graph embeddings
# ──────────────────────────────────────────
KG_EMBEDDING_PROVIDER=gemini
KG_EMBEDDING_MODEL=gemini-embedding-001
KG_EMBEDDING_DIMENSION=3072

# ──────────────────────────────────────────
# Live Search (Tavily — optional)
# Required only for legal_consultation mode live search fallback
# ──────────────────────────────────────────
TAVILY_API_KEY=your-tavily-api-key-here

# ──────────────────────────────────────────
# CORS — add your production domain(s)
# ──────────────────────────────────────────
# CORS_ORIGINS=["https://app.lexguardian.vn","https://www.lexguardian.vn"]

# ──────────────────────────────────────────
# Feature flags
# ──────────────────────────────────────────
NEXUSRAG_ENABLE_KG=true
LEGAL_STATIC_INDEX_ENABLED=false
ENABLE_GENERIC_RAG_API=true
